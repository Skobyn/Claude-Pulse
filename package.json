{
  "name": "claude-pulse",
  "version": "0.1.0",
  "description": "Local-first activity tracker for Claude Code — tracks sessions, decisions, and progress across projects",
  "keywords": ["claude", "claude-code", "activity-tracker", "developer-tools", "dashboard", "sqlite"],
  "license": "MIT",
  "author": "Clemens Hoenig",
  "repository": {
    "type": "git",
    "url": "https://github.com/Clemens865/Claude-Pulse.git"
  },
  "bin": {
    "claude-pulse": "./bin/claude-pulse.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "hook/",
    "src/",
    ".next/standalone/",
    ".next/static/",
    "public/",
    "next.config.ts",
    "tsconfig.json",
    "postcss.config.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev --port 3141",
    "build": "next build",
    "start": "next start --port 3141",
    "lint": "eslint .",
    "prepublishOnly": "npm run build && node bin/copy-static.mjs",
    "postinstall": "node bin/postinstall.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
